{
  "info": {
    "name": "Kabooz Goli Soda — Full API Collection",
    "description": "Complete test collection for Kabooz Goli Soda backend.\nBase URL: http://localhost:8080\n\nHOW TO USE:\n1. Run 'Admin Login' first — token is auto-saved\n2. All admin requests auto-use the saved token\n3. Run 'Create Admin Order' to get an order ID for other tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8080", "type": "string" },
    { "key": "jwt_token",      "value": "", "type": "string",   "description": "Auto-set after login" },
    { "key": "order_id",       "value": "1", "type": "string",  "description": "Auto-set after Create Order" },
    { "key": "invoice_no",     "value": "",  "type": "string",  "description": "Auto-set after Create Order" }
  ],
  "item": [
    {
      "name": "🔐 1. AUTH",
      "item": [
        {
          "name": "Login — Admin (kabooz@2024) ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(res.token).to.not.be.undefined);",
                  "pm.test('idleTimeoutSeconds = 600', () => pm.expect(res.idleTimeoutSeconds).to.eql(600));",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('jwt_token', res.token);",
                  "  console.log('✅ Token saved. Expires in:', res.expiresIn, 'seconds');",
                  "  console.log('Idle timeout:', res.idleTimeoutSeconds, 'seconds (10 min)');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"kabooz@2024\"\n}"
            }
          }
        },
        {
          "name": "Login — Wrong Password ❌ (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const res = pm.response.json();",
                  "pm.test('Error = Unauthorized', () => pm.expect(res.error).to.eql('Unauthorized'));",
                  "pm.test('Has message', () => pm.expect(res.message).to.include('Invalid'));",
                  "pm.test('Has timestamp', () => pm.expect(res.timestamp).to.not.be.undefined);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpass\"\n}" }
          }
        },
        {
          "name": "Login — Empty Body ❌ (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "const res = pm.response.json();",
                  "pm.test('Validation Failed', () => pm.expect(res.error).to.eql('Validation Failed'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"\",\n  \"password\": \"\"\n}" }
          }
        }
      ]
    },
