                  "const res = pm.response.json();",
                  "pm.test('Glass bottlesPerCrate = 24', () => pm.expect(res.glass.bottlesPerCrate).to.eql(24));",
                  "pm.test('PET bottlesPerCase = 30', () => pm.expect(res.pet.bottlesPerCase).to.eql(30));",
